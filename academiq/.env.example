# ============================================================
# ACADEMIQ — Variables d'environnement (PRODUCTION)
# Copier ce fichier en « .env » sur le serveur puis compléter les valeurs.
# NE JAMAIS committer le vrai .env (il est ignoré par git).
# ============================================================

# --- Sécurité Django ---
# Générer une clé unique :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=remplace-moi-par-une-cle-secrete-unique

# Désactiver le mode debug en production
DJANGO_DEBUG=False

# Ton sous-domaine, SANS https:// (séparer par des virgules si plusieurs)
DJANGO_ALLOWED_HOSTS=academiq.tondomaine.fr

# Origines de confiance CSRF, AVEC https://
DJANGO_CSRF_TRUSTED_ORIGINS=https://academiq.tondomaine.fr

# Forcer la redirection HTTPS : passer à True une fois le certificat SSL actif
DJANGO_SSL_REDIRECT=False

# --- Base de données MySQL / MariaDB (créée dans cPanel) ---
# Sur O2Switch, le nom de base et l'utilisateur sont préfixés par ton compte cPanel.
DB_ENGINE=mysql
DB_NAME=toncompte_academiq
DB_USER=toncompte_academiq
DB_PASSWORD=mot_de_passe_de_la_base
DB_HOST=localhost
DB_PORT=3306
